# Copy this file to .env.local for local development:
#   cp .env.example .env.local
# Never commit .env.local — it's already in .gitignore.
#
# On Vercel, set these under Project Settings -> Environment Variables
# instead of committing a real .env file.

# ---------------------------------------------------------------------------
# App URL
# ---------------------------------------------------------------------------
# Used to build fully-qualified invoice payment links and Open Graph/social
# preview metadata. No trailing slash.
#
# Local dev:
#   NEXT_PUBLIC_APP_URL=http://localhost:3000
# Production (Vercel): set this to your real deployed domain, e.g.
#   NEXT_PUBLIC_APP_URL=https://your-project.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---------------------------------------------------------------------------
# Supabase
# ---------------------------------------------------------------------------
# Project Settings -> API Keys in your Supabase dashboard.
# Use the "Publishable" key (starts with sb_publishable_...) — NOT the secret
# key. The secret key (sb_secret_...) must never be used in a NEXT_PUBLIC_
# variable, since those are shipped to the browser bundle.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your-key-here

# ---------------------------------------------------------------------------
# Arc Testnet
# ---------------------------------------------------------------------------
NEXT_PUBLIC_ARC_CHAIN_ID=5042002
NEXT_PUBLIC_ARC_RPC_URL=https://rpc.testnet.arc.network
NEXT_PUBLIC_ARC_EXPLORER_URL=https://explorer.testnet.arc.network

# ---------------------------------------------------------------------------
# Optional: WalletConnect
# ---------------------------------------------------------------------------
# Only needed if you add the walletConnect connector in src/lib/wagmi.ts.
# Get a project id from https://cloud.walletconnect.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
